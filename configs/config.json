{
    "dataset": {
        "root_dir": "data",
        "input_size": [224, 224],
        "batch_size": 32,
        "num_workers": 4
    },
    "model": {
        "cnn_backbone": "resnet18",
        "vit_backbone": "vit_base_patch16_224",
        "dummy_input_shape": [1, 3, 224, 224],
        "num_classes": 1
    },
    "training": {
        "learning_rate": 0.001,
        "num_epochs": 20,
        "patience": 5,
        "optimizer": "adam",
        "criterion": "bce_with_logits"
    },
    "output_dir": "outputs"
}